NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# W25 D14 Phase 1 — Supabase Realtime (브라우저 직접 구독, anon key 사용).
# Service Role Key 는 절대 NEXT_PUBLIC_ prefix 로 노출 금지.
# D1 Phase B — Auth(아키텍처 B)도 동일 URL/anon key 재사용.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# D1 Phase B — Auth (멀티유저, plan §1.1).
# NEXT_PUBLIC_SITE_URL: OAuth redirect 기준 URL (prod: https://jetrag.woong-s.com,
#   dev: http://localhost:3001). 미설정 시 localhost:3001 fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# NEXT_PUBLIC_COOKIE_DOMAIN: 형제 서브도메인 세션 쿠키 공유용. prod 만 설정
#   (예: .woong-s.com → jetrag / jetrag-api 공유). dev 는 비워 두면 host-only(localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=
