# Jet-Rag 환경변수 템플릿 — 값을 실제 키로 바꾼 뒤 이 파일을 .env 로 복사해 사용.
# 실제 .env 파일은 .gitignore 로 커밋되지 않음.

# Supabase (Dashboard → Settings)
# - Project URL:  Settings → Data API (또는 General → Project ID 로 조립)
# - anon key:     Settings → API Keys → Legacy API keys → anon (public)
# - service_role: Settings → API Keys → Legacy API keys → service_role (secret, RLS 우회)
#   ⚠ service_role 키는 백엔드 전용. 절대 프론트/공개 repo/클라이언트 번들에 노출 금지.
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Supabase Storage bucket 이름 (기본값: documents)
SUPABASE_STORAGE_BUCKET=documents

# Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=<gemini-api-key>

# Hugging Face (https://huggingface.co/settings/tokens)
# - BGE-M3 dense 임베딩을 HF Inference API 로 호출하기 위한 Read 토큰
HF_API_TOKEN=<hf-api-token>

# 단일 사용자 MVP: 인증 도입(W5) 전까지 모든 업로드가 이 user_id 로 귀속.
# W5 auth 도입 시 실제 auth.uid() 로 대체되고 이 변수는 제거됨.
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# ============================================================
# W15~W18 누적 운영 env (선택, default 동작 정상)
# ============================================================
# 마이그레이션 005·006 적용 후 자동 활성. 미적용 시 graceful skip (in-memory metrics 만).

# DB write-through 활성/비활성. "0" 시 in-memory metrics 만 동작 (단위 테스트 패턴).
# JET_RAG_METRICS_PERSIST_ENABLED=1

# ThreadPoolExecutor fire-and-forget vs sync. "1" (default) 운영 latency 보호.
# "0" 시 sync 호출 (단위 테스트 first-warn capture race 회피).
# JET_RAG_METRICS_PERSIST_ASYNC=1

# vision_usage_log.error_msg 의 truncate 길이 (DB row 크기 보호).
# 음수/비숫자 시 default 200 fallback.
# JET_RAG_VISION_ERROR_MSG_MAX_LEN=200

# search_metrics_log.query_text 를 SHA256 hash 화. 멀티 유저 도입 시 PII 보호.
# "1" 시 64자 hex 저장. default "0" (평문, 단일 사용자 MVP).
# JET_RAG_QUERY_TEXT_HASH=0

# ============================================================
# 2026-05-06 D2-C — vision sweep × retry 곱셈 제거 (master plan §7.3)
# ============================================================
# default 정책 (sweep 2 × retry 1 = worst case 페이지당 2 호출, 50p PDF = 100 호출).
# 이전 (sweep 3 × retry 3 = 450 호출) 대비 4.5x 절감. 정상 환경에서는 1 차 sweep
# 에서 모두 성공 → latency 영향 0. 회귀 (HTTP/2 ConnectionTerminated, 503 폭주 등)
# 발생 시 아래 두 ENV 로 즉시 회복.
#
# JETRAG_PDF_VISION_ENRICH_MAX_SWEEPS=3   # 페이지 단위 누락 재시도 sweep 수 (default 2)
# JETRAG_GEMINI_RETRY=3                    # Gemini API 호출당 retry 수 (default 1)

# ============================================================
# 2026-05-07 S0 D3 — vision 비용 cap budget 초기값 (master plan §7.5)
# ============================================================
# vision_usage_log 1주 누적 데이터 기반 산정값. scripts/compute_budget.py 로 재산정.
# 데이터 누적 부족 시 (n<30 row 또는 unique_doc<5) 잠정값 사용.
# 잠정 default: doc $0.10 (~138 KRW), daily $0.50 (~690 KRW), 5 docs/일 가정.
#
# JETRAG_DOC_BUDGET_USD=0.10        # 문서당 vision cost cap
# JETRAG_DAILY_BUDGET_USD=0.50       # 일일 vision cost cap (24h 누적)
# JETRAG_BUDGET_KRW_PER_USD=1380     # 환율 (KRW 환산용, 운영 리포트만)
#
# scripts/compute_budget.py ENV:
# BUDGET_LOOKBACK_DAYS=7    # 최근 N일 데이터 (default 7)
# BUDGET_DAILY_DOCS=5       # 일일 인제스트 doc 가정 (default 5)
# BUDGET_KRW_PER_USD=1380   # 환율 (default 1380)

# ============================================================
# 2026-05-08 S2 D1 — vision_need_score 운영 hook 토글 (master plan §6 S2 D1)
# ============================================================
# PyMuPDF 분석 → OR rule (text_density / table_like / image_area / text_quality / caption)
# → needs_vision False 페이지는 vision 호출 회피. S1.5 D3 본 PC 5 PDF 측정에서 약 36%
# 페이지 회피 가설 (needs_vision_or = 64.3%). 골든셋 v1 vision_diagram + table_lookup
# recall 5/6 (83.3%) baseline 유지.
#
# default true. 회복 토글 — false 시 모든 페이지 vision 호출 (S1.5 이전 동작 100% 보존).
# JETRAG_VISION_NEED_SCORE_ENABLED=true

# ============================================================
# 2026-05-08 S2 D2 — vision page cap (master plan §6 S2 D2)
# ============================================================
# 단일 doc 안 vision call 페이지 cap. cost cap (doc/daily/24h_sliding) 과 직교 —
# 둘 중 먼저 닿는 지점 stop. needs_vision skip 페이지는 카운터 증가 X (사용자 가치
# 페이지만 차감, cap 도달 지연 정합).
#
# default 50 — S0 D3 본 PC 5 PDF 측정 평균 21.5p/doc × 2.3배 안전 margin.
# 0 또는 음수 시 무한 (회복 토글 — page cap 영향 0).
# JETRAG_VISION_PAGE_CAP_PER_DOC=50

# ============================================================
# 2026-05-09 S2 D3 — 운영 모드 (fast / default / precise) UI 토글 (master plan §6 S2 D3)
# ============================================================
# 사용자 결정 Q-S2-1b: fast=10 / default=50 (위 ENV) / precise=0 (무한).
# 본 ENV 는 fast 모드의 page_cap 만 조정. default/precise 는 매핑이 고정.
#
# 우선순위 (Q-S2-1e A 안):
#   - JETRAG_VISION_PAGE_CAP_PER_DOC=0 (위 ENV) 시 mode 무관 항상 무한 (전역 kill switch)
#   - 그 외엔 mode 별 page_cap 사용 (fast=본 ENV, default=위 ENV, precise=0)
#
# JETRAG_VISION_MODE_FAST_CAP=10

# ============================================================
# 2026-05-09 S3 D3 — gated paid query decomposition (planner v0.1 §C)
# ============================================================
# intent_router (S3 D1) 가 needs_decomposition=True 로 판정한 query 를 Gemini
# 2.5 Flash-Lite 로 2~5 sub-query 분해 → 원본 query top_k=20 + sub-query top_k=10
# RRF merge 로 recall 향상. cross-doc / 비교 / 인과 / 복수대상 의도 우선 대상.
#
# default OFF — 본 ENV true 명시 + intent_router needs_decomposition=True 둘 다
# 만족해야 LLM 호출. 비용 추정 ~$0.0001/호출 + LRU cache 200건.
# JETRAG_PAID_DECOMPOSITION_ENABLED=false
#
# 월간 분해 비용 cap (USD). vision_usage_log 의 source_type='query_decomposition'
# 누적 SUM 으로 집계 (UTC 1일~now). 초과 시 호출 skip + reason 마킹 (graceful).
# JETRAG_DECOMPOSITION_MONTHLY_CAP_USD=0.30
#
# LRU cache 비활성 토글 (디버깅용). default 0 (캐시 ON, 200건).
# JETRAG_DECOMPOSITION_CACHE_DISABLE=0
#
# M1 W-1(a) — `/search` 의 분해 LLM 호출 timeout(초). 초과 시 분해 skip
# (원본 query 단독 검색, 회귀 0). 범위 [1, 30] clamp. default 5.
# JETRAG_DECOMPOSITION_TIMEOUT_SEC=5

# ============================================================
# M1 W-1(b) — `/search` cross_doc-scoped 검색 (옵션 A, 마이그 0)
# ============================================================
# cross_doc-class query (intent_router T1_cross_doc / T2_compare / T7_multi_target
# 중 하나라도 발화) 한정으로 RPC 결과를 doc 단위로 그룹화 → doc score 상위 N doc 만
# 유지 → 나머지 doc 의 chunk 제외. W-1(a) paid decomposition 의 P2 함정 (sub-query
# 풀이 글로벌이라 noise doc chunk 가 라벨 doc chunk 의 RRF rank 를 밀어내는 회귀)
# 을 production 측에서 후보 doc set 식별 + 필터만으로 회피.
#
# default OFF — W-1(a) ENV 와 직교 (각자 독립 토글). ON 시 단일-doc / non-cross_doc
# query 는 영향 0 (게이트 4조건 AND).
# JETRAG_CROSS_DOC_SCOPED_SEARCH=false
#
# 후보 doc set 크기. 범위 [2, 10] clamp, invalid → default 4. golden_v2 cross_doc
# 9 row 의 ground-truth target doc 가 2~4 개 분포라 default 4 권고. 큰 값일수록
# noise 회피 효과↓ + 회귀 위험↓.
# JETRAG_CROSS_DOC_CANDIDATE_TOP_N=4

# ============================================================
# S3 D4 — reranker cap + cache + free-tier degrade + MMR 다양성
# ============================================================
# BGE-reranker (HF API) 의 무료 티어 폭주 방지 4중 가드:
#   (1) candidate cap     — RPC top-K 중 reranker 에 전달할 최대 후보 수
#   (2) in-memory cache   — 같은 (query, chunk_ids) 재호출 시 HF 호출 0
#   (3) free-tier degrade — 월간 호출 누적이 임계 도달 시 RRF score 로 fallback
#   (4) MMR 다양성        — cross-doc query 한정 doc-level 다양성 후처리

# (1) cap — `JETRAG_RERANKER_CANDIDATE_CAP` (default 20, 권장 5~50).
# 범위 밖 / 비숫자 값은 default 로 graceful 회복.
# JETRAG_RERANKER_CANDIDATE_CAP=20

# (2) cache 비활성 토글 (디버깅용). default 0 (캐시 ON, 500건 LRU).
# JETRAG_RERANKER_CACHE_DISABLE=0

# (3) 월간 호출 cap + degrade 임계율. vision_usage_log 의
#     source_type='reranker_invoke' COUNT 로 집계 (최근 30일). 누적 ≥ cap × threshold
#     도달 시 path=degraded — HF 호출 skip + RRF score 그대로 정렬 (검색 자체 차단 X).
# JETRAG_RERANKER_MONTHLY_CAP_CALLS=1000
# JETRAG_RERANKER_DEGRADE_THRESHOLD=0.8

# (4) MMR — λ=relevance 가중 (1.0=pure relevance, 0.0=pure diversity).
#     cross-doc query (intent_router T1_cross_doc) 한정 doc-level 후처리.
# JETRAG_MMR_LAMBDA=0.7
# JETRAG_MMR_DISABLE=0

# ============================================================
# 2026-05-13 M1 W-2 (S4-D) — 인제스트 단계 동의어 후보 사전 (검색 정확도 80% PRD §3 W-2)
# ============================================================
# 사용자가 문서에 없는 어휘(외래어·약어·일상어·이형 표기)로 검색해 sparse path
# (PGroonga `&@~`) 가 0 hits 되는 synonym_mismatch 회귀를, 인제스트 시점에 chunk text
# 끝에 `[검색어: ...]` 동의어 마커를 주입해 회복한다. (검색 측 query_expansion 의 query
# 확장과 방향이 반대 — 이쪽은 corpus 측 보강. 같은 어휘를 의도적으로 공유.)
#
# (1) ENABLED — true 시 인제스트 때 정적 사전(app/services/synonym_dict.py) 키 매칭으로
#     chunk text 끝에 `[검색어: ...]` 마커 + metadata.synonym_candidates / metadata.
#     synonym_source 주입. **인제스트 시점 ENV** 라 켰다 꺼도 이미 박힌 chunk 는
#     재인제스트 전까지 안 바뀜. M2 W-4 전체 클린 재인제스트 때 켜고 ON/OFF ablation eval.
#     default false — 켜기 전까지 인제스트·검색 동작 100% 무변경.
# JETRAG_SYNONYM_INJECTION_ENABLED=false
#
# (2) LLM — true 시 doc당 1회 Flash-Lite 호출로 (term, synonyms) 쌍을 추가 생성해
#     마커 후보에 합산 (chunk 루프 밖 1회, graceful — 실패 시 빈 list). ENABLED=true 일
#     때만 의미. 무료 RPD(1,500/일) 안, quota 시 graceful skip. 최소 구현 — 프롬프트
#     정교화는 M2. default false.
# JETRAG_SYNONYM_INJECTION_LLM=false
#
# (3) (2) 가 사용하는 모델 override. 미설정 시 default gemini-2.5-flash-lite
#     (factory `_GEMINI_DEFAULT_MODELS["synonym"]`).
# JETRAG_LLM_MODEL_SYNONYM=gemini-2.5-flash-lite
